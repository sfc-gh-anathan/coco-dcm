create or replace   view DBT_DCM_DEMO.STAGING_DEV.stg_clients
  
   as (
    WITH source AS (
    SELECT * FROM DBT_DCM_DEMO.RAW_DEV.clients
)

SELECT
    CLIENT_ID,
    TRIM(CLIENT_NAME) AS CLIENT_NAME,
    UPPER(REGION) AS REGION,
    EMPLOYEE_COUNT,
